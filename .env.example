# Duffel API token. Test tokens (duffel_test_...) return synthetic "Duffel Airways" data;
# live tokens return real bookable fares. Get one at https://app.duffel.com
DUFFEL_TOKEN=

# Provider: "duffel" or "fixture". Defaults to duffel when DUFFEL_TOKEN is set, else fixture.
# The fixture provider generates deterministic synthetic itineraries for development/tests.
PROVIDER=

PORT=3000
DB_PATH=data/cache.db

# Set to require a shared password on the UI and API (username: group).
# Strongly recommended before sharing the app publicly (npm run share).
SHARE_PASSWORD=
